# URL publique absolue. Utiliser l'URL locale en développement et l'URL propre
# à chaque environnement Vercel (Development, Preview ou Production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Valeurs publiques du projet Supabase. Elles peuvent être exposées au navigateur.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret strictement serveur : ne jamais l'importer dans un composant client.
SUPABASE_SERVICE_ROLE_KEY=

# Ajouter ces variables séparément dans Vercel pour chaque environnement.
# Le fichier .env.local sert au développement local et ne doit jamais être commité.
